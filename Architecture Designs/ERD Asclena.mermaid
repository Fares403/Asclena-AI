        %%{init: {'theme': 'base', 'themeVariables': {
        'background': '#F8FAFC',
        'primaryColor': '#E3F2FD',
        'primaryTextColor': '#0F172A',
        'primaryBorderColor': '#1E88E5',
        'lineColor': '#334155',
        'secondaryColor': '#E8F5E9',
        'tertiaryColor': '#FFF3E0'
    }}}%%
erDiagram

    %% ══════════════════════════════════════════════
    %% AUTH & USER DOMAIN
    %% ══════════════════════════════════════════════

    User {
        bigint      user_id         PK
        varchar     first_name
        varchar     last_name
        varchar     email
        varchar     password
        varchar     phone
        boolean     is_active
        datetime    created_at
    }

    Role {
        bigint      role_id         PK
        varchar     role_name
    }

    UserRole {
        bigint      user_id         PK,FK
        bigint      role_id         PK,FK
        datetime    assigned_at
    }

    Permission {
        bigint      permission_id   PK
        varchar     code
    }

    RolePermission {
        bigint      role_id         PK,FK
        bigint      permission_id   PK,FK
    }

    Screen {
        bigint      screen_id               PK
        varchar     code
        varchar     path
        varchar     module
        bigint      required_permission_id  FK
        boolean     is_active
    }

    AuditLog {
        bigint      audit_log_id    PK
        bigint      user_id         FK
        varchar     action
        varchar     entity_type
        bigint      entity_id
        datetime    created_at
    }

    %% ══════════════════════════════════════════════
    %% STAFF PROFILES
    %% ══════════════════════════════════════════════

    Doctor {
        bigint      doctor_id           PK,FK
        varchar     specialty
        varchar     license_number
    }

    LabStaff {
        bigint      lab_staff_id        PK,FK
        varchar     lab_department
    }

    RadiologyStaff {
        bigint      radiology_staff_id  PK,FK
        varchar     imaging_department
    }

    Receptionist {
        bigint      receptionist_id     PK,FK
    }

    %% ══════════════════════════════════════════════
    %% PATIENT DOMAIN
    %% ══════════════════════════════════════════════

    Patient {
        bigint      patient_id              PK
        varchar     mrn
        varchar     first_name
        varchar     last_name
        varchar     national_id
        date        dob
        varchar     gender
        varchar     phone
        varchar     email
        varchar     address
        varchar     blood_type
        decimal     initial_weight
        decimal     initial_height
        decimal     initial_BMI
        varchar     initial_blood_pressure
    }

    PatientInsurance {
        bigint      insurance_id    PK
        bigint      patient_id      FK
        varchar     company
        varchar     policy_number
        varchar     class
        date        expiry_date
        boolean     is_active
    }

    PatientEmergencyContact {
        bigint      contact_id      PK
        bigint      patient_id      FK
        varchar     name
        varchar     relationship
        varchar     phone
        boolean     is_primary
        datetime    created_at
    }

    PatientAllergy {
        bigint      allergy_id      PK
        bigint      patient_id      FK
        varchar     allergen
        varchar     severity
        varchar     reaction
        boolean     is_active
    }

    %% ══════════════════════════════════════════════
    %% CASE & EPISODE DOMAIN
    %% ══════════════════════════════════════════════

    CaseRecord {
        bigint      case_id             PK
        bigint      patient_id          FK
        varchar     primary_diagnosis
        date        start_date
        date        end_date
        boolean     is_active
        decimal     risk_score
        varchar     risk_level
        text        summary
    }

    Episode {
        bigint      episode_id      PK
        bigint      case_id         FK
        date        start_date
        date        end_date
        varchar     status
    }

    EpisodeClinicalNote {
        bigint      note_id         PK
        bigint      episode_id      FK
        varchar     note_type
        text        content
        bigint      created_by      FK
        datetime    created_at
    }

    %% ══════════════════════════════════════════════
    %% VITALS DOMAIN
    %% ══════════════════════════════════════════════

    VitalType {
        bigint      vital_type_id   PK
        varchar     code
        varchar     name
    }

    Unit {
        bigint      unit_id         PK
        varchar     code
        varchar     name
    }

    VitalSign {
        bigint      measurement_id  PK
        bigint      episode_id      FK
        bigint      vital_type_id   FK
        decimal     value
        bigint      unit_id         FK
        datetime    measured_at
        bigint      recorded_by     FK
    }

    %% ══════════════════════════════════════════════
    %% LAB DOMAIN
    %% ══════════════════════════════════════════════

    LabOrder {
        bigint      lab_order_id    PK
        bigint      episode_id      FK
        bigint      ordered_by      FK
        datetime    order_date
        varchar     status
        varchar     priority
    }

    LabResult {
        bigint      lab_result_id   PK
        bigint      lab_order_id    FK
        varchar     status
        bigint      reviewed_by     FK
        datetime    reviewed_at
    }

    LabResultItem {
        bigint      lab_result_item_id  PK
        bigint      lab_result_id       FK
        varchar     analyte_code
        varchar     value
        varchar     unit
        varchar     reference_range_text
        varchar     flag
    }

    %% ══════════════════════════════════════════════
    %% IMAGING DOMAIN
    %% ══════════════════════════════════════════════

    ImagingOrder {
        bigint      imaging_order_id    PK
        bigint      episode_id          FK
        bigint      ordered_by          FK
        varchar     modality
        varchar     body_part
        varchar     status
        datetime    order_date
    }

    ImagingResult {
        bigint      imaging_result_id   PK
        bigint      imaging_order_id    FK
        text        findings
        text        conclusion
        text        report_text
        bigint      reviewed_by         FK
        datetime    reviewed_at
    }

    %% ══════════════════════════════════════════════
    %% PRESCRIPTION DOMAIN
    %% ══════════════════════════════════════════════

    Medication {
        bigint      medication_id   PK
        varchar     name
    }

    Prescription {
        bigint      prescription_id PK
        bigint      episode_id      FK
        bigint      medication_id   FK
        varchar     dose
        varchar     frequency
        varchar     duration
        varchar     status
        bigint      prescribed_by   FK
        datetime    start_date
        datetime    end_date
    }

    %% ══════════════════════════════════════════════
    %% APPOINTMENT DOMAIN
    %% ══════════════════════════════════════════════

    Appointment {
        bigint      appointment_id      PK
        bigint      patient_id          FK
        bigint      doctor_id           FK
        bigint      receptionist_id     FK
        datetime    scheduled_date_time
        varchar     status
        datetime    check_in_time
        datetime    start_time
        datetime    end_time
        datetime    created_at
    }

    %% ══════════════════════════════════════════════
    %% PATIENT DOMAIN (Updated with 'race')
    %% ══════════════════════════════════════════════

    Patient {
        bigint      patient_id              PK "subject_id"
        varchar     mrn
        varchar     first_name
        varchar     last_name
        varchar     gender
        varchar     race                    "Added from edstays"
        date        dob
        varchar     blood_type
        varchar     phone
        varchar     email
    }

    %% ══════════════════════════════════════════════
    %% CASE & EPISODE DOMAIN (Merged with edstays)
    %% ══════════════════════════════════════════════

    CaseRecord {
        bigint      case_id                 PK
        bigint      patient_id              FK
        varchar     primary_diagnosis
        boolean     is_active
        decimal     risk_score
    }

    Episode {
        bigint      episode_id              PK "stay_id"
        bigint      case_id                 FK
        bigint      hadm_id                 "Added from edstays"
        datetime    intime                  "Added from edstays"
        datetime    outtime                 "Added from edstays"
        varchar     arrival_transport       "Added from edstays"
        varchar     disposition             "Added from edstays"
        varchar     status
    }

    %% ══════════════════════════════════════════════
    %% CLINICAL DATA (Triage, Vitals, Diagnosis)
    %% ══════════════════════════════════════════════

    Triage {
        bigint      triage_id               PK
        bigint      episode_id              FK
        decimal     temperature
        integer     heartrate
        integer     resprate
        integer     o2sat
        integer     sbp
        integer     dbp
        varchar     pain
        integer     acuity
        text        chiefcomplaint
    }

    VitalSign {
        bigint      measurement_id          PK
        bigint      episode_id              FK
        datetime    charttime               "Added from vitalsign samples"
        decimal     temperature             "Mapped directly"
        integer     heartrate               "Mapped directly"
        integer     resprate                "Mapped directly"
        integer     o2sat                   "Mapped directly"
        integer     sbp                     "Mapped directly"
        integer     dbp                     "Mapped directly"
        varchar     rhythm                  "Added from vitalsign samples"
        varchar     pain                    "Added from vitalsign samples"
        bigint      vital_type_id           FK "Original ERD column"
        decimal     value                   "Original ERD column"
        bigint      unit_id                 FK "Original ERD column"
    }

    Diagnosis {
        bigint      diagnosis_id            PK
        bigint      episode_id              FK
        integer     seq_num                 "Added from diagnosis samples"
        varchar     icd_code                "Added from diagnosis samples"
        integer     icd_version             "Added from diagnosis samples"
        varchar     icd_title               "Added from diagnosis samples"
    }

    %% ══════════════════════════════════════════════
    %% MEDICATION LOGS (MedRecon & Pyxis)
    %% ══════════════════════════════════════════════

    MedRecon {
        bigint      med_recon_id            PK
        bigint      episode_id              FK
        datetime    charttime
        varchar     name
        varchar     gsn
        varchar     ndc
        integer     etc_rn
        varchar     etccode
        text        etcdescription
    }

    Pyxis {
        bigint      pyxis_id                PK
        bigint      episode_id              FK
        datetime    charttime
        integer     med_rn
        varchar     name
        integer     gsn_rn
        varchar     gsn
    }

    %% ══════════════════════════════════════════════
    %% RELATIONSHIPS
    %% ══════════════════════════════════════════════

    Patient      ||--o{ CaseRecord     : "has"
    CaseRecord   ||--o{ Episode        : "contains"
    
    Episode      ||--o| Triage         : "initial assessment"
    Episode      ||--o{ VitalSign      : "monitors"
    Episode      ||--o{ Diagnosis      : "recorded for"
    Episode      ||--o{ MedRecon       : "history"
    Episode      ||--o{ Pyxis          : "dispensed via"

    %% ══════════════════════════════════════════════
    %% 1. METADATA & LOOKUP TABLES
    %% ══════════════════════════════════════════════

    Ref_Transport {
        integer     id              PK
        varchar     name            "Ambulance, Walk-in, Helicopter..."
    }

    Ref_Disposition {
        integer     id              PK
        varchar     name            "Home, Admitted, Transfer, Expired..."
    }

    Ref_ICD {
        varchar     icd_code        PK
        integer     icd_version     "9 or 10"
        varchar     description
    }

    Ref_Medication {
        varchar     gsn             PK
        varchar     name
        varchar     drug_class
    }

    %% ══════════════════════════════════════════════
    %% 2. AUTH & STAFF (With Audit Trail
    %% ══════════════════════════════════════════════

    User {
        bigint      user_id         PK
        varchar     email           UK
        varchar     password
        boolean     is_active
        datetime    created_at      "Audit Trail"
        datetime    updated_at
    }

    AuditLog {
        bigint      audit_log_id    PK
        bigint      user_id         FK
        varchar     action
        varchar     entity_type
        bigint      entity_id
        datetime    created_at
    }

    %% ══════════════════════════════════════════════
    %% 3. PATIENT & CASE DOMAIN
    %% ══════════════════════════════════════════════

    Patient {
        bigint      patient_id              PK
        varchar     mrn                     UK
        varchar     first_name
        varchar     last_name
        varchar     gender
        varchar     race
        date        dob
        datetime    created_at
    }

    CaseRecord {
        bigint      case_id                 PK
        bigint      patient_id              FK
        boolean     is_active
        decimal     risk_score              "ML Predicted Score"
        varchar     risk_level              "High/Med/Low"
        datetime    created_at
    }

    Episode {
        bigint      episode_id              PK
        bigint      case_id                 FK
        bigint      hadm_id                 "Hospital Admission ID"
        datetime    intime                  "Indexed for Performance"
        datetime    outtime
        integer     transport_id            FK
        integer     disposition_id          FK
        varchar     status
        datetime    created_at
    }

    %% ══════════════════════════════════════════════
    %% 4. CLINICAL DATA (Performance Optimized)
    %% ══════════════════════════════════════════════

    Triage {
        bigint      triage_id               PK
        bigint      episode_id              FK
        decimal     temperature
        integer     heartrate
        integer     resprate
        integer     o2sat
        integer     sbp
        integer     dbp
        decimal     shock_index             "Calculated Column"
        integer     acuity
        text        chiefcomplaint
        datetime    created_at
    }

    VitalSign {
        bigint      measurement_id          PK
        bigint      episode_id              FK
        datetime    charttime               "Indexed for Trends"
        integer     sbp
        integer     dbp
        integer     heartrate
        integer     resprate
        integer     o2sat
        varchar     rhythm
        bigint      recorded_by             FK
    }

    Diagnosis {
        bigint      diagnosis_id            PK
        bigint      episode_id              FK
        varchar     icd_code                FK
        integer     seq_num                 "Primary/Secondary"
        datetime    created_at
    }

    %% ══════════════════════════════════════════════
    %% 5. MEDICATIONS (Med Details )
    %% ══════════════════════════════════════════════

    Pyxis {
        bigint      pyxis_id                PK
        bigint      episode_id              FK
        varchar     gsn                     FK
        datetime    charttime
        decimal     dose
        varchar     unit
        varchar     route
        varchar     status
    }

    MedRecon {
        bigint      med_recon_id            PK
        bigint      episode_id              FK
        varchar     gsn                     FK
        varchar     name
        datetime    charttime
    }

    %% ══════════════════════════════════════════════
    %% RELATIONSHIPS
    %% ══════════════════════════════════════════════

    User            ||--o{ AuditLog                : "generates"
    Patient         ||--o{ CaseRecord              : "has"
    CaseRecord      ||--o{ Episode                 : "contains"
    
    %% Clinical
    Episode         ||--o| Triage                  : "initial assessment"
    Episode         ||--o{ VitalSign               : "monitors"
    Episode         ||--o{ Diagnosis               : "records"
    Episode         ||--o{ Pyxis                   : "dispenses"
    Episode         ||--o{ MedRecon                : "reconciles"

    %% Lookups
    Episode         ||--o{ Ref_Transport           : "arrives via"
    Episode         ||--o{ Ref_Disposition         : "discharged to"
    Diagnosis       ||--o{ Ref_ICD                 : "references"
    Pyxis           ||--o{ Ref_Medication          : "dispenses"
    MedRecon        ||--o{ Ref_Medication          : "history of"


    %% ══════════════════════════════════════════════
    %% RELATIONSHIPS
    %% ══════════════════════════════════════════════

    %% Auth & Roles
    User            ||--o{    UserRole                : "assigned to"
    Role            ||--o{    UserRole                : "assigned to"
    Role            ||--o{    RolePermission          : "grants"
    Permission      ||--o{    RolePermission          : "included in"
    Permission      ||--o{    Screen                  : "required for"
    User            ||--o{    AuditLog                : "generates"

    %% Staff Profiles (extend User)
    User            ||--o|    Doctor                  : "profile"
    User            ||--o|    LabStaff                : "profile"
    User            ||--o|    RadiologyStaff          : "profile"
    User            ||--o|    Receptionist            : "profile"

    %% Patient relationships
    Patient         ||--o{    PatientInsurance        : "has"
    Patient         ||--o{    PatientEmergencyContact : "has"
    Patient         ||--o{    PatientAllergy          : "has"
    Patient         ||--o{    CaseRecord              : "has"
    Patient         ||--o{    Appointment             : "books"

    %% Case & Episode
    CaseRecord      ||--o{    Episode                 : "contains"
    Episode         ||--o{    EpisodeClinicalNote     : "has"

    %% Vitals
    Episode         ||--o{    VitalSign               : "records"
    VitalType       ||--o{    VitalSign               : "defines"
    Unit            ||--o{    VitalSign               : "uses"
    User            ||--o{    VitalSign               : "recorded by"

    %% Lab
    Episode         ||--o{    LabOrder                : "orders"
    Doctor          ||--o{    LabOrder                : "ordered by"
    LabOrder        ||--o|    LabResult               : "produces"
    LabResult       ||--o{    LabResultItem           : "contains"
    LabStaff        ||--o{    LabResult               : "reviews"

    %% Imaging
    Episode         ||--o{    ImagingOrder            : "orders"
    Doctor          ||--o{    ImagingOrder            : "ordered by"
    ImagingOrder    ||--o|    ImagingResult           : "produces"
    RadiologyStaff  ||--o{    ImagingResult           : "reviews"

    %% Prescriptions
    Episode         ||--o{    Prescription            : "includes"
    Medication      ||--o{    Prescription            : "used in"
    Doctor          ||--o{    Prescription            : "prescribes"

    %% Appointments
    Doctor          ||--o{    Appointment             : "sees"
    Receptionist    ||--o{    Appointment             : "manages"

    %% Clinical Notes
    User            ||--o{    EpisodeClinicalNote     : "created by"